@model List<DSM.Models.Entities.Service>

@{
    ViewData["Title"] = "Manage Services";
}

<style>

    body {
        background: #f4f6fb;
        font-family: 'Segoe UI';
    }

    /* SIDEBAR */
    .sidebar {
        width: 260px;
        height: 100vh;
        background: #0f172a;
        color: white;
        position: fixed;
        padding: 20px;
    }

        .sidebar h2 {
            margin-bottom: 25px;
        }

        .sidebar a {
            display: block;
            color: #cbd5e1;
            padding: 12px;
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 10px;
        }

            .sidebar a:hover {
                background: #1e293b;
                color: white;
            }


    /* MAIN */

    .main {
        margin-left: 290px;
        padding: 40px;
        min-height: 100vh;
    }

    /* TOPBAR */

    .topbar {
        background: white;
        padding: 30px;
        border-radius: 22px;
        margin-bottom: 35px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
    }

        .topbar h1 {
            font-size: 50px;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 10px;
        }

        .topbar p {
            font-size: 20px;
            color: #64748b;
            margin: 0;
        }

    .badge-box {
        background: #0f172a;
        color: white;
        padding: 12px 22px;
        border-radius: 14px;
        font-weight: 700;
    }

    /* ADD BUTTON */

    .btn-add {
        background: linear-gradient(135deg,#2563eb,#1d4ed8);
        color: white;
        text-decoration: none;
        padding: 14px 28px;
        border-radius: 14px;
        font-size: 16px;
        font-weight: 700;
        transition: 0.3s;
        display: inline-block;
    }

        .btn-add:hover {
            color: white;
            transform: translateY(-3px);
        }

    /* CARD */

    .service-card {
        border: none;
        border-radius: 25px;
        overflow: hidden;
        transition: 0.3s;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        height: 100%;
    }

        .service-card:hover {
            transform: translateY(-8px);
        }

    .service-image {
        height: 240px;
        width: 100%;
        object-fit: cover;
    }

    .card-body-custom {
        padding: 25px;
    }

    .service-title {
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 15px;
    }

    .service-desc {
        color: #64748b;
        font-size: 16px;
        margin-bottom: 20px;
    }

    .price {
        color: #16a34a;
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 15px;
    }

    .provider-name {
        font-size: 16px;
        font-weight: 600;
        color: #334155;
        margin-bottom: 20px;
    }

    /* STATUS */

    .status-badge {
        padding: 10px 20px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: 700;
    }

    .approved {
        background: #dcfce7;
        color: #166534;
    }

    .pending {
        background: #fef3c7;
        color: #92400e;
    }

    .rejected {
        background: #fee2e2;
        color: #991b1b;
    }

    /* BUTTONS */

    .action-buttons {
        display: flex;
        gap: 12px;
        margin-top: 25px;
    }

    .btn-edit {
        flex: 1;
        background: #2563eb;
        color: white;
        text-align: center;
        padding: 12px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-edit:hover {
            background: #1d4ed8;
            color: white;
        }

    .btn-delete {
        flex: 1;
        background: #ef4444;
        color: white;
        text-align: center;
        padding: 12px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-delete:hover {
            background: #dc2626;
            color: white;
        }

</style>

<!-- SIDEBAR -->

<div class="sidebar">

    <h2>Provider Panel</h2>

    <a asp-action="Dashboard">
        🏠 Dashboard
    </a>

    <a asp-action="AddService">
        ➕ Add Service
    </a>

    <a asp-action="ManageServices"
       class="active-menu">
        🛎️ My Services
    </a>

    <a asp-controller="Booking"
       asp-action="BookingRequests">
        📦 Booking Requests
    </a>

    <a asp-action="EditProfile">
        👤 Edit Profile
    </a>

    <hr style="border-color:#334155;" />

    <a asp-action="Logout"
       style="color:#f87171;">
        🚪 Logout
    </a>

</div>

<!-- MAIN -->

<div class="main">

    <!-- TOPBAR -->

    <div class="topbar">

        <div>

            <h1>My Services</h1>

            <p>
                Manage all your listed services professionally
            </p>

        </div>

        <div>

            <a asp-action="AddService"
               class="btn-add">

                + Add New Service

            </a>

        </div>

    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 shadow-sm mb-4">

            @TempData["Success"]

        </div>
    }

    <!-- SERVICES -->

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">

                <div class="service-card">

                    <!-- IMAGE -->

                    <img src="@item.PhotoURL"
                         class="service-image" />

                    <!-- BODY -->

                    <div class="card-body-custom">

                        <div class="service-title">

                            @item.ServiceName

                        </div>

                        <div class="service-desc">

                            @item.Description

                        </div>

                        <div class="price">

                            ₹ @item.Price

                        </div>

                        <div class="provider-name">

                            Provider :
                            @item.ProviderName

                        </div>

                        <!-- STATUS -->
                        @if (item.Status == "Approved")
                        {
                            <span class="status-badge approved">

                                ✅ Approved

                            </span>
                        }
                        else if (item.Status == "Rejected")
                        {
                            <span class="status-badge rejected">

                                ❌ Rejected

                            </span>
                        }
                        else
                        {
                            <span class="status-badge pending">

                                ⏳ Pending

                            </span>
                        }

                        <!-- BUTTONS -->

                        <div class="action-buttons">

                            <a asp-action="EditService"
                               asp-route-id="@item.ServiceId"
                               class="btn-edit">

                                Edit

                            </a>

                            <a asp-action="DeleteService"
                               asp-route-id="@item.ServiceId"
                               class="btn-delete"
                               onclick="return confirm('Are you sure you want to delete this service?')">

                                Delete

                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>