@{
    ViewData["Title"] = "Provider Login";
}

<style>

    body {
        background: linear-gradient(to right,#eef2ff,#f8fbff);
        font-family: 'Segoe UI', sans-serif;
    }

    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .login-card {
        border: none;
        border-radius: 30px;
        overflow: hidden;
        background: white;
    }

    /* LEFT SIDE */

    .left-side {
        background: linear-gradient(135deg,#0f172a,#1e3a8a,#2563eb);
        color: white;
        padding: 60px 45px;
        position: relative;
    }

        .left-side::before {
            content: "";
            position: absolute;
            top: -50px;
            right: -50px;
            width: 220px;
            height: 220px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
        }

        .left-side::after {
            content: "";
            position: absolute;
            bottom: -60px;
            left: -60px;
            width: 250px;
            height: 250px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
        }

    .brand-title {
        font-size: 42px;
        font-weight: 800;
        line-height: 60px;
        position: relative;
        z-index: 2;
    }

    .brand-subtitle {
        margin-top: 20px;
        line-height: 30px;
        color: rgba(255,255,255,0.85);
        position: relative;
        z-index: 2;
    }

    .feature-box {
        background: rgba(255,255,255,0.10);
        border: 1px solid rgba(255,255,255,0.12);
        padding: 18px 20px;
        border-radius: 18px;
        margin-top: 20px;
        backdrop-filter: blur(10px);
        position: relative;
        z-index: 2;
    }

        .feature-box h6 {
            font-weight: 700;
        }

        .feature-box p {
            margin: 0;
            font-size: 14px;
            color: rgba(255,255,255,0.8);
        }

    /* RIGHT SIDE */

    .form-section {
        padding: 70px 50px;
    }

    .main-title {
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .sub-title {
        color: #6b7280;
        margin-bottom: 35px;
    }

    .form-label {
        font-weight: 600;
        color: #1e293b;
    }

    .form-control {
        height: 56px;
        border-radius: 16px;
        border: 1px solid #dbe2ea;
        padding-left: 18px;
    }

        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(37,99,235,0.12);
            border-color: #2563eb;
        }

    .login-btn {
        height: 58px;
        border-radius: 18px;
        border: none;
        background: linear-gradient(to right,#2563eb,#1d4ed8);
        font-size: 18px;
        font-weight: 700;
        transition: 0.3s;
        color: white;
    }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(37,99,235,0.25);
        }

    .register-link {
        color: #2563eb;
        font-weight: 700;
        text-decoration: none;
    }

</style>

<div class="container login-wrapper">

    <div class="card shadow-lg login-card w-100">

        <div class="row g-0">

            <!-- LEFT SIDE -->

            <div class="col-lg-5">

                <div class="left-side h-100 d-flex flex-column justify-content-center">

                    <h1 class="brand-title">
                        Welcome Back Provider
                    </h1>

                    <p class="brand-subtitle">
                        Login to manage your services, bookings and customers in DSM platform.
                    </p>

                    <div class="feature-box">
                        <h6>📊 Track Bookings</h6>
                        <p>Manage all your service requests easily.</p>
                    </div>

                    <div class="feature-box">
                        <h6>💼 Grow Business</h6>
                        <p>Increase your reach and earn more customers.</p>
                    </div>

                    <div class="feature-box">
                        <h6>⚡ Fast Access</h6>
                        <p>Quick dashboard access anytime.</p>
                    </div>

                </div>

            </div>

            <!-- RIGHT SIDE -->

            <div class="col-lg-7">

                <div class="form-section">

                    <h2 class="main-title">Provider Login</h2>

                    <p class="sub-title">
                        Enter your credentials to continue
                    </p>

                    <form method="post">

                        <div class="mb-4">

                            <label class="form-label">Email</label>

                            <input type="email"
                                   name="Email"
                                   class="form-control"
                                   placeholder="Enter email"
                                   required />

                        </div>

                        <div class="mb-4">

                            <label class="form-label">Password</label>

                            <input type="password"
                                   name="Password"
                                   class="form-control"
                                   placeholder="Enter password"
                                   required />

                        </div>

                        <button type="submit" class="login-btn w-100">
                            Login
                        </button>

                    </form>

                    <div class="text-center mt-4">

                        <span class="text-muted">
                            Don't have an account?
                        </span>

                        <br />

                        <a asp-action="Register" class="register-link">
                            Register Here
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>