@{
    ViewData["Title"] = "Admin Login";
}

<style>
    body {
        background: #0f172a;
    }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        width: 100%;
        max-width: 450px;
        background: #ffffff;
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.4);
        animation: fadeIn 0.6s ease-in-out;
    }

    .auth-title {
        font-weight: 800;
        font-size: 28px;
        color: #0f172a;
        text-align: center;
        margin-bottom: 5px;
    }

    .auth-subtitle {
        color: #64748b;
        font-size: 14px;
        text-align: center;
        margin-bottom: 25px;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px;
    }

        .form-control:focus {
            box-shadow: none;
            border-color: #000;
        }

    .btn-custom {
        background: #0f172a;
        color: #fff;
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-custom:hover {
            background: #1e293b;
            transform: translateY(-2px);
        }

    .alert {
        border-radius: 12px;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="auth-wrapper">

    <div class="auth-card">

        <h1 class="auth-title">Admin Login</h1>

        <p class="auth-subtitle">
            Secure access to admin dashboard
        </p>

        <form asp-action="Login" method="post">

            <div class="mb-3">

                <label class="form-label">Username</label>

                <input type="text"
                       name="username"
                       class="form-control"
                       placeholder="Enter username" />

            </div>

            <div class="mb-3">

                <label class="form-label">Password</label>

                <input type="password"
                       name="password"
                       class="form-control"
                       placeholder="Enter password" />

            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <button type="submit" class="btn btn-custom w-100">
                Login
            </button>

        </form>

    </div>

</div>