<div class="container mt-5">
@model List<DSM.Models.Entities.User>

@{
    ViewData["Title"] = "Manage Users";
}

<style>

    body {
        background: #f4f7fc;
        font-family: 'Segoe UI';
    }

    /* SIDEBAR */

        .sidebar {
            width: 260px;
            height: 100vh;
            background: #0f172a;
            color: white;
            position: fixed;
            padding: 20px;
        }

            .sidebar h2 {
                margin-bottom: 25px;
            }

            .sidebar a {
                display: block;
                color: #cbd5e1;
                padding: 12px;
                text-decoration: none;
                border-radius: 10px;
                margin-bottom: 10px;
            }

                .sidebar a:hover {
                    background: #1e293b;
                    color: white;
                }


    /* MAIN */

    .main-content {
        margin-left: 280px;
        padding: 35px;
    }

    /* HEADER */

    .topbar {
        background: white;
        padding: 22px;
        border-radius: 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

        .topbar h2 {
            font-weight: 700;
            margin: 0;
        }

    .badge-admin {
        background: #0f172a;
        color: white;
        padding: 10px 18px;
        border-radius: 12px;
        font-size: 14px;
    }

    /* TABLE CARD */

    .table-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .table {
        margin-bottom: 0;
    }

        .table thead {
            background: #0f172a;
            color: white;
        }

            .table thead th {
                padding: 16px;
                border: none;
            }

        .table tbody td {
            padding: 16px;
            vertical-align: middle;
        }

    .btn-edit {
        background: #f59e0b;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 14px;
        margin-right: 6px;
    }

    .btn-delete {
        background: #dc2626;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 14px;
    }

        .btn-edit:hover,
        .btn-delete:hover {
            color: white;
            opacity: 0.9;
        }

</style>

    <!-- SIDEBAR -->
    <div class="sidebar">

        <h2>Admin Panel</h2>

        <a asp-controller="Admin" asp-action="Dashboard">🏠 Dashboard</a>
        <a asp-controller="Admin" asp-action="ManageUsers">👥 Manage Users</a>
        <a asp-controller="Admin" asp-action="ManageProviders">🧑‍🔧 Providers</a>
        <a asp-controller="Category" asp-action="Index">📂 Categories</a>
        <a asp-controller="Admin" asp-action="ManageServices">🛎️ Services</a>
        <a asp-controller="Admin" asp-action="ApproveServices">✅ Approvals</a>

        <hr style="border-color:#334155;" />

        <a asp-controller="Admin" asp-action="Logout" style="color:#f87171;">
            🚪 Logout
        </a>

    </div>

<!-- MAIN CONTENT -->

<div class="main-content">

    <!-- TOPBAR -->

    <div class="topbar">

        <div>

            <h2>Manage Users</h2>

            <p class="text-muted mb-0">
                View, edit and manage all platform users
            </p>

        </div>

        <span class="badge-admin">
            Admin Dashboard
        </span>

    </div>

    <!-- TABLE -->

    <div class="table-card">

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead>

                    <tr>

                        <th>ID</th>

                        <th>Name</th>

                        <th>Email</th>

                        <th>Phone</th>

                        <th width="220">Action</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                #@item.UserId
                            </td>

                            <td class="fw-semibold">
                                @item.Name
                            </td>

                            <td>
                                @item.Email
                            </td>

                            <td>
                                @item.Phone
                            </td>

                            <td>

                                <a asp-action="EditUser"
                                   asp-route-id="@item.UserId"
                                   class="btn-edit">

                                    Edit

                                </a>

                                <a asp-action="DeleteUser"
                                   asp-route-id="@item.UserId"
                                   class="btn-delete"
                                   onclick="return confirm('Delete this user?')">

                                    Delete

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>