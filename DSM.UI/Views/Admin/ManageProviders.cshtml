<div class="container mt-5">
@model List<DSM.Models.Entities.Provider>

@{
    ViewData["Title"] = "Manage Providers";
}

<style>

    body {
        background: #f4f6fb;
        font-family: 'Segoe UI';
    }

    /* SIDEBAR */

        .sidebar {
            width: 260px;
            height: 100vh;
            background: #0f172a;
            color: white;
            position: fixed;
            padding: 20px;
        }

            .sidebar h2 {
                margin-bottom: 25px;
            }

            .sidebar a {
                display: block;
                color: #cbd5e1;
                padding: 12px;
                text-decoration: none;
                border-radius: 10px;
                margin-bottom: 10px;
            }

                .sidebar a:hover {
                    background: #1e293b;
                    color: white;
                }

    /* MAIN */

    .main {
        margin-left: 280px;
        padding: 40px;
    }

    /* TOPBAR */

    .topbar {
        background: white;
        padding: 20px 30px;
        border-radius: 18px;
        margin-bottom: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .topbar h1 {
            font-size: 38px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }

        .topbar p {
            color: gray;
            margin: 0;
        }

    /* TABLE CARD */

    .table-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        overflow-x: auto;
    }

    /* TABLE */

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table thead {
            background: #0f172a;
            color: white;
        }

        .custom-table th {
            padding: 18px;
            font-size: 15px;
        }

        .custom-table td {
            padding: 18px;
            vertical-align: middle;
            border-bottom: 1px solid #e2e8f0;
        }

        .custom-table tbody tr:hover {
            background: #f8fafc;
        }

    /* BUTTONS */

    .btn-edit {
        background: #f59e0b;
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
        margin-right: 8px;
    }

        .btn-edit:hover {
            background: #d97706;
            color: white;
        }

    .btn-delete {
        background: #dc2626;
        color: white;
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-delete:hover {
            background: #b91c1c;
            color: white;
        }

    .badge-box {
        background: #e2e8f0;
        color: #0f172a;
        padding: 8px 16px;
        border-radius: 30px;
        font-weight: 600;
    }

</style>

    <!-- SIDEBAR -->
    <div class="sidebar">

        <h2>Admin Panel</h2>

        <a asp-controller="Admin" asp-action="Dashboard">🏠 Dashboard</a>
        <a asp-controller="Admin" asp-action="ManageUsers">👥 Manage Users</a>
        <a asp-controller="Admin" asp-action="ManageProviders">🧑‍🔧 Providers</a>
        <a asp-controller="Category" asp-action="Index">📂 Categories</a>
        <a asp-controller="Admin" asp-action="ManageServices">🛎️ Services</a>
        <a asp-controller="Admin" asp-action="ApproveServices">✅ Approvals</a>

        <hr style="border-color:#334155;" />

        <a asp-controller="Admin" asp-action="Logout" style="color:#f87171;">
            🚪 Logout
        </a>

    </div>
<!-- MAIN -->

<div class="main">

    <!-- TOPBAR -->

    <div class="topbar">

        <div>

            <h1>Manage Providers</h1>

            <p>Manage all registered service providers</p>

        </div>

        <span class="badge-box">

            Total Providers:
            @Model.Count

        </span>

    </div>

    <!-- TABLE -->

    <div class="table-card">

        <table class="custom-table">

            <thead>

                <tr>

                    <th>ID</th>

                    <th>Name</th>

                    <th>Email</th>

                    <th>Phone</th>

                    <th>Action</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            #@item.ProviderId
                        </td>

                        <td>
                            @item.Name
                        </td>

                        <td>
                            @item.Email
                        </td>

                        <td>
                            @item.Phone
                        </td>

                        <td>

                            <a asp-action="EditProvider"
                               asp-route-id="@item.ProviderId"
                               class="btn-edit">

                                Edit

                            </a>

                            <a asp-action="DeleteProvider"
                               asp-route-id="@item.ProviderId"
                               class="btn-delete">

                                Delete

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>