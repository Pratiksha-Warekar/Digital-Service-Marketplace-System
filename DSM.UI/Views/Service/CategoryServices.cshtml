@{
    ViewData["Title"] = "Services";
}

<div class="bg-dark text-white p-5 rounded-4 shadow">

    <h1 class="display-5 fw-bold">

        @ViewBag.Category Services

    </h1>

    <p class="lead">

        Trusted professionals for your home services

    </p>

</div>

<div class="row mt-5">

    <!-- SERVICE CARD 1 -->

    <div class="col-md-4 mb-4">

        <div class="card border-0 shadow-lg rounded-4 h-100">

            <img src="~/images/service1.jpg"
                 class="card-img-top rounded-top-4"
                 height="250" />

            <div class="card-body">

                <h4 class="fw-bold">
                    Premium Service
                </h4>

                <p class="text-muted">

                    Experienced professionals with quality service.

                </p>

                <h5 class="text-success fw-bold">
                    ₹499
                </h5>

                <div class="mt-3">

                    <a asp-controller="Booking"
                       asp-action="Create"
                       class="btn btn-dark w-100 rounded-3">

                        Book Now

                    </a>

                </div>

            </div>

        </div>

    </div>

    <!-- SERVICE CARD 2 -->

    <div class="col-md-4 mb-4">

        <div class="card border-0 shadow-lg rounded-4 h-100">

            <img src="~/images/service2.jpg"
                 class="card-img-top rounded-top-4"
                 height="250" />

            <div class="card-body">

                <h4 class="fw-bold">
                    Expert Technician
                </h4>

                <p class="text-muted">

                    Fast and reliable doorstep services.

                </p>

                <h5 class="text-success fw-bold">
                    ₹799
                </h5>

                <div class="mt-3">

                    <a asp-controller="Booking"
                       asp-action="Create"
                       class="btn btn-dark w-100 rounded-3">

                        Book Now

                    </a>

                </div>

            </div>

        </div>

    </div>

    <!-- SERVICE CARD 3 -->

    <div class="col-md-4 mb-4">

        <div class="card border-0 shadow-lg rounded-4 h-100">

            <img src="~/images/service3.jpg"
                 class="card-img-top rounded-top-4"
                 height="250" />

            <div class="card-body">

                <h4 class="fw-bold">
                    Professional Support
                </h4>

                <p class="text-muted">

                    Affordable and trusted home service.

                </p>

                <h5 class="text-success fw-bold">
                    ₹999
                </h5>

                <div class="mt-3">

                    <a asp-controller="Booking"
                       asp-action="Create"
                       class="btn btn-dark w-100 rounded-3">

                        Book Now

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>