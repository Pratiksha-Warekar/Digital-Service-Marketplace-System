@model DSM.Models.Entities.Service

<div class="container mt-5">

    <div class="card shadow p-4">

        <div class="row">

            <div class="col-md-6">

                <img src="@Model.PhotoURL"
                     class="img-fluid rounded"
                     style="height:400px;
                            width:100%;
                            object-fit:cover;" />

            </div>

            <div class="col-md-6">

                <h2>
                    @Model.ServiceName
                </h2>

                <p class="mt-3">

                    @Model.Description

                </p>

                <h3 class="text-success">

                    ₹@Model.Price

                </h3>

                <a asp-controller="Booking"
                   asp-action="Create"
                   asp-route-serviceId="@Model.ServiceId"
                   class="btn btn-primary mt-3">

                    Book Now

                </a>

            </div>

        </div>

    </div>

</div>