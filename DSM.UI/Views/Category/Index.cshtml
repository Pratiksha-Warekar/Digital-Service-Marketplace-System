@model IEnumerable<DSM.Models.Entities.Category>

@{
    ViewData["Title"] = "Categories";
}

<style>

    body {
        background: #f4f6fb;
        font-family: 'Segoe UI';
    }

    /* SIDEBAR */
    .sidebar {
        width: 260px;
        height: 100vh;
        background: #0f172a;
        color: white;
        position: fixed;
        padding: 20px;
    }

        .sidebar h2 {
            margin-bottom: 25px;
        }

        .sidebar a {
            display: block;
            color: #cbd5e1;
            padding: 12px;
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 10px;
            transition: 0.3s;
        }

            .sidebar a:hover {
                background: #1e293b;
                color: white;
            }

    /* ACTIVE LINK */
    .active-link {
        background: #2563eb;
        color: white !important;
    }

    /* MAIN */
    .main {
        margin-left: 270px;
        padding: 25px;
    }

    /* TOPBAR */
    .topbar {
        background: white;
        padding: 22px;
        border-radius: 12px;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

        .topbar h2 {
            margin: 0;
            font-weight: 700;
        }

        .topbar p {
            margin: 0;
            color: gray;
        }

    /* BUTTON */
    .btn-add {
        background: #2563eb;
        color: white;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
    }

        .btn-add:hover {
            background: #1d4ed8;
            color: white;
        }

    /* TABLE CARD */
    .table-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    /* TABLE */
    .custom-table {
        width: 100%;
    }

        .custom-table thead {
            border-bottom: 2px solid #e2e8f0;
        }

        .custom-table th {
            padding: 18px;
            font-size: 18px;
        }

        .custom-table td {
            padding: 18px;
            font-size: 16px;
            vertical-align: middle;
            border-bottom: 1px solid #e2e8f0;
        }

    /* BUTTONS */
    .btn-edit {
        background: #f59e0b;
        color: white;
        padding: 8px 14px;
        border-radius: 8px;
        text-decoration: none;
        margin-right: 8px;
    }

    .btn-delete {
        background: #ef4444;
        color: white;
        padding: 8px 14px;
        border-radius: 8px;
        text-decoration: none;
    }

</style>

<!-- SIDEBAR -->
<div class="sidebar">

    <h2>Admin Panel</h2>

    <a asp-controller="Admin" asp-action="Dashboard">
        🏠 Dashboard
    </a>

    <a asp-controller="Admin" asp-action="ManageUsers">
        👥 Manage Users
    </a>

    <a asp-controller="Admin" asp-action="ManageProviders">
        🧑‍🔧 Providers
    </a>

    <a asp-controller="Category"
       asp-action="Index"
       class="active-link">
        📂 Categories
    </a>

    <a asp-controller="Admin" asp-action="ManageServices">
        🛎️ Services
    </a>

    <a asp-controller="Admin" asp-action="ApproveServices">
        ✅ Approvals
    </a>

    <hr style="border-color:#334155;" />

    <a asp-controller="Admin"
       asp-action="Logout"
       style="color:#f87171;">
        🚪 Logout
    </a>

</div>

<!-- MAIN -->
<div class="main">

    <!-- TOPBAR -->
    <div class="topbar">

        <div>
            <h2>📂 Categories</h2>
            <p>Manage all service categories</p>
        </div>

        <a asp-action="Create"
           class="btn-add">
            + Add Category
        </a>

    </div>

    <!-- TABLE -->
    <div class="table-card">

        <table class="table custom-table">

            <thead>

                <tr>
                    <th>ID</th>
                    <th>Category Name</th>
                    <th width="220">Action</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            #@item.CategoryId
                        </td>

                        <td>
                            @item.CategoryName
                        </td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-id="@item.CategoryId"
                               class="btn-edit">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.CategoryId"
                               class="btn-delete">
                                Delete
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>