@model DSM.Models.Entities.User

@{
    ViewData["Title"] = "Register";
}

<style>

    body {
        background: #0f172a;
    }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px;
    }

    .auth-card {
        width: 100%;
        max-width: 500px;
        background: #ffffff;
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.4);
    }

    .auth-title {
        font-weight: 800;
        font-size: 30px;
        color: #0f172a;
    }

    .auth-subtitle {
        color: #64748b;
        margin-bottom: 25px;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px;
    }

        .form-control:focus {
            box-shadow: none;
            border-color: #0f172a;
        }

    textarea.form-control {
        height: 100px;
    }

    .btn-custom {
        background: #0f172a;
        color: white;
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        border: none;
    }

        .btn-custom:hover {
            background: #1e293b;
        }

    .link-text {
        color: #0f172a;
        text-decoration: none;
        font-weight: 600;
    }

</style>

<div class="auth-wrapper">

    <div class="auth-card">

        <div class="text-center mb-4">

            <h1 class="auth-title">
                Create Account
            </h1>

            <p class="auth-subtitle">
                Join Digital Service Marketplace
            </p>

        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">

                @ViewBag.Error

            </div>
        }

        <form asp-action="Register" method="post">

            <div class="mb-3">

                <label class="form-label">
                    Full Name
                </label>

                <input asp-for="Name"
                       class="form-control"
                       placeholder="Enter your name" />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Email Address
                </label>

                <input asp-for="Email"
                       class="form-control"
                       placeholder="Enter email" />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Password
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="Enter password" />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Phone Number
                </label>

                <input asp-for="Phone"
                       class="form-control"
                       placeholder="Enter mobile number" />

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Address
                </label>

                <textarea asp-for="Address"
                          class="form-control"
                          placeholder="Enter your address"></textarea>

            </div>

            <button type="submit"
                    class="btn btn-custom w-100">

                Register

            </button>

        </form>

        <div class="text-center mt-4">

            <span class="text-muted">
                Already have an account?
            </span>

            <br />

            <a asp-controller="Account"
               asp-action="Login"
               class="link-text">

                Login here

            </a>

        </div>

    </div>

</div>