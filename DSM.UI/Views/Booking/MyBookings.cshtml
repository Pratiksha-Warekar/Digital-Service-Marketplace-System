@model IEnumerable<DSM.Models.Entities.BookingRequest>

@{
    ViewData["Title"] = "My Bookings";
}

<style>

    body {
        background: #f4f6fb;
        font-family: 'Segoe UI';
    }

    /* SIDEBAR */

    .sidebar {
        width: 260px;
        height: 100vh;
        background: #0f172a;
        color: white;
        position: fixed;
        padding: 20px;
    }

        .sidebar h2 {
            margin-bottom: 25px;
        }

        .sidebar a {
            display: block;
            color: #cbd5e1;
            padding: 12px;
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 10px;
        }

            .sidebar a:hover {
                background: #1e293b;
                color: white;
            }

    /* MAIN */

    .main {
        margin-left: 280px;
        padding: 40px;
    }

    /* TOPBAR */

    .topbar {
        background: white;
        padding: 18px;
        border-radius: 12px;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .badge-box {
        background: #0f172a;
        color: white;
        padding: 6px 14px;
        border-radius: 8px;
    }

    /* BOOKING CARD */

    .booking-card {
        background: white;
        border-radius: 18px;
        overflow: hidden;
        transition: 0.3s;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        height: 100%;
    }

        .booking-card:hover {
            transform: translateY(-6px);
        }

    .booking-image {
        width: 100%;
        height: 220px;
        object-fit: cover;
    }

    .booking-body {
        padding: 20px;
    }

    .address-box {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 12px;
        border-radius: 10px;
    }

    .status-approved {
        background: #16a34a;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 13px;
    }

    .status-rejected {
        background: #dc2626;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 13px;
    }

    .status-pending {
        background: #f59e0b;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 13px;
    }

</style>

<!-- SIDEBAR -->

<div class="sidebar">

    <h2>👤 User Panel</h2>

    <a asp-controller="Account"
       asp-action="Dashboard">
        🏠 Dashboard
    </a>

    <a asp-controller="Booking"
       asp-action="MyBookings">
        📦 Booking History
    </a>

    <a asp-controller="Account"
       asp-action="EditProfile">
        👤 Profile
    </a>

    <hr style="border-color:#334155;" />

    <a asp-controller="Account"
       asp-action="Logout"
       style="color:#f87171;">
        🚪 Logout
    </a>

</div>

<!-- MAIN -->

<div class="main">

    <div class="topbar">

        <h3>📦 My Bookings</h3>

        <span class="badge-box">
            User Dashboard
        </span>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card p-5 text-center">

            <h4>No Bookings Found</h4>

            <p class="text-muted">
                You haven't booked any services yet.
            </p>

        </div>
    }
    else
    {
        <div class="row">

            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">

                    <div class="booking-card">

                        <img src="@item.PhotoURL"
                             class="booking-image" />

                        <div class="booking-body">

                            <div class="mb-3">

                                @if (item.Status == "Approved")
                                {
                                    <span class="status-approved">
                                        Approved
                                    </span>
                                }
                                else if (item.Status == "Rejected")
                                {
                                    <span class="status-rejected">
                                        Rejected
                                    </span>
                                }
                                else
                                {
                                    <span class="status-pending">
                                        Pending
                                    </span>
                                }

                            </div>

                            <h5 class="fw-bold">
                                @item.ServiceName
                            </h5>

                            <p class="text-muted mb-2">
                                Provider: @item.ProviderName
                            </p>

                            <p>
                                <strong>₹ @item.Price</strong>
                            </p>

                            <p class="text-muted">
                                @item.BookingDate.ToString("dd MMM yyyy")
                            </p>

                            <div class="address-box">

                                <small class="text-muted">
                                    Address
                                </small>

                                <br />

                                @item.Address

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>