@{
    ViewData["Title"] = "Home";
}

<!-- ================= HERO SECTION ================= -->

<section class="hero-section text-white d-flex align-items-center">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <span class="badge bg-warning text-dark px-3 py-2 mb-3 fs-6">
                    Trusted Home Services Platform
                </span>

                <h1 class="display-3 fw-bold mb-4">
                    Find Trusted
                    <span class="text-warning">Home Services</span>
                    Near You
                </h1>

                <p class="lead mb-4 text-light">
                    Book professional electricians, plumbers,
                    painters, salon experts and more with just one click.
                </p>

                <!-- ================= SEARCH FORM ================= -->

                <form action="/Service/Index"
                      method="get"
                      class="row g-3 mb-5">

                    <!-- SEARCH BOX -->

                    <div class="col-md-8 position-relative">

                        <input type="text"
                               id="searchBox"
                               name="search"
                               class="form-control form-control-lg shadow-sm border-0 rounded-4 px-4"
                               placeholder="Search services like Electrician, AC Repair..."
                               autocomplete="off" />

                        <!-- LIVE SEARCH RESULTS -->

                        <div id="searchResults"
                             class="list-group position-absolute w-100 mt-2 shadow"
                             style="z-index:9999; border-radius:15px; overflow:hidden;">
                        </div>

                    </div>

                    <!-- BUTTON -->

                    <div class="col-md-4">

                        <button type="submit"
                                class="btn btn-warning btn-lg w-100 rounded-4 fw-bold shadow-sm">

                            Search Service

                        </button>

                    </div>

                </form>

                <!-- ================= LIVE SEARCH SCRIPT ================= -->

                <script>

                    const searchBox =
                        document.getElementById("searchBox");

                    const searchResults =
                        document.getElementById("searchResults");

                    searchBox.addEventListener("keyup", function () {

                        let term = searchBox.value;

                        // EMPTY

                        if (term.length == 0) {

                            searchResults.innerHTML = "";

                            return;
                        }

                        // FETCH API

                        fetch('/Service/SearchServices?term=' + term)

                            .then(response => response.json())

                            .then(data => {

                                searchResults.innerHTML = "";

                                data.forEach(item => {

                                    searchResults.innerHTML += `

                                        <a href="/Service/Details/${item.id}"
                                           class="list-group-item list-group-item-action">

                                            ${item.serviceName}

                                        </a>

                                    `;
                                });

                            });

                    });

                </script>

                <!-- ================= STATS ================= -->

                <div class="row mt-5">

                    <div class="col-4">
                        <h2 class="fw-bold">25+</h2>
                        <p class="text-light">Services</p>
                    </div>

                    <div class="col-4">
                        <h2 class="fw-bold">25+</h2>
                        <p class="text-light">Providers</p>
                    </div>

                    <div class="col-4">
                        <h2 class="fw-bold">1K+</h2>
                        <p class="text-light">Customers</p>
                    </div>

                </div>

            </div>

            <!-- RIGHT IMAGE -->

            <div class="col-lg-6 text-center">

                <img src="~/images/homepage.jpg"
                     class="img-fluid hero-image" />

            </div>

        </div>

    </div>

</section>

